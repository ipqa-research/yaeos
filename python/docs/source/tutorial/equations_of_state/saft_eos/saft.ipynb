       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "z = [0.5, 0.5]\n",
    "\n",
    "env = model.phase_envelope_pt(z, kind=\"dew\", p0=0.01)\n",
    "\n",
    "env.plot()"
   ]
