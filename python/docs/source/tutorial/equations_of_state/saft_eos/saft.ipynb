   "source": [
    "import yaeos\n",
    "\n",
    "m = [1.0582, 3.3004]\n",
    "epsilon_k = [145.5257, 224.0780]\n",
    "sigma = [3.6316, 3.8639]\n",
    "model = yaeos.PCSAFT(m, sigma, epsilon_k)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "16e01088",
   "metadata": {},
   "outputs": [
    {
     "data": {
